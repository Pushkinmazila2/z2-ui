# zapret2 configuration for Docker container
# This is an example configuration file
# Copy this to 'config' and modify as needed

# TMPDIR for temporary files
TMPDIR=/opt/zapret2/tmp

# User for zapret daemons
#WS_USER=nobody

# Firewall type (iptables or nftables)
# In container we use iptables
FWTYPE=iptables

# Options for ipsets
SET_MAXELEM=522288
IPSET_OPT="hashsize 262144 maxelem $SET_MAXELEM"

# Options for ip2net
IP2NET_OPT4="--prefix-length=22-30 --v4-threshold=3/4"
IP2NET_OPT6="--prefix-length=56-64 --v6-threshold=5"

# Autohostlist options
AUTOHOSTLIST_INCOMING_MAXSEQ=4096
AUTOHOSTLIST_RETRANS_MAXSEQ=32768
AUTOHOSTLIST_RETRANS_RESET=1
AUTOHOSTLIST_RETRANS_THRESHOLD=3
AUTOHOSTLIST_FAIL_THRESHOLD=3
AUTOHOSTLIST_FAIL_TIME=60
AUTOHOSTLIST_UDP_IN=1
AUTOHOSTLIST_UDP_OUT=4
AUTOHOSTLIST_DEBUGLOG=0

# Domain list resolve threads
MDIG_THREADS=30
MDIG_EAGAIN=10
MDIG_EAGAIN_DELAY=500

# Compress large lists
GZIP_LISTS=1

# Mark bits
DESYNC_MARK=0x40000000
DESYNC_MARK_POSTNAT=0x20000000

# Enable nfqws2
NFQWS2_ENABLE=1

# Ports to redirect
NFQWS2_PORTS_TCP=80,443
NFQWS2_PORTS_UDP=443

# Packet limits for conntrack
NFQWS2_TCP_PKT_OUT=20
NFQWS2_TCP_PKT_IN=10
NFQWS2_UDP_PKT_OUT=5
NFQWS2_UDP_PKT_IN=3

# nfqws2 options
# Example 1: Basic HTTP + HTTPS strategy
NFQWS2_OPT="
--filter-tcp=80,443 --filter-l7=http,tls
--out-range=-d10
--payload=http_req --lua-desync=fake:blob=fake_default_http:tcp_md5 --lua-desync=multisplit:pos=method+2 --new
--payload=tls_client_hello --lua-desync=fake:blob=fake_default_tls:tcp_md5:repeats=6 --lua-desync=multidisorder:pos=midsld --new
--filter-udp=443 --filter-l7=quic
--payload=quic_initial --lua-desync=fake:blob=fake_default_quic:repeats=6
"

# Example 2: Aggressive strategy for specific sites
# Uncomment and modify as needed
#NFQWS2_OPT="
#--filter-tcp=443 --filter-l7=tls --hostlist=/opt/zapret2/lists/blocked.txt
#--out-range=-d10
#--payload=tls_client_hello --lua-desync=fake:blob=fake_default_tls:tcp_md5:repeats=11:tls_mod=rnd,dupsid,sni=www.google.com --lua-desync=multidisorder:pos=1,midsld
#"

# Example 3: YouTube specific
#NFQWS2_OPT="
#--filter-tcp=443 --filter-l7=tls --hostlist=/opt/zapret2/lists/youtube.txt
#--out-range=-d10
#--payload=tls_client_hello --lua-desync=fake:blob=fake_default_tls:tcp_md5:repeats=11:tls_mod=dupsid,sni=www.google.com --lua-desync=multidisorder:pos=1,midsld --new
#--filter-udp=443 --filter-l7=quic --hostlist=/opt/zapret2/lists/youtube.txt
#--payload=quic_initial --lua-desync=fake:blob=fake_default_quic:repeats=11
#"

# Mode filter: none, ipset, hostlist, autohostlist
MODE_FILTER=none

# Flow offload: donttouch, none, software, hardware
FLOWOFFLOAD=donttouch

# Disable IPv6 (recommended in container)
DISABLE_IPV6=1

# Filter ICMP time exceeded
FILTER_TTL_EXPIRED_ICMP=1