# ============================================================================
# Zapret2 Docker - Конфигурация через переменные окружения
# ============================================================================
# Скопируйте этот файл в .env и настройте под свои нужды:
# cp docker/environment.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# SOCKS5 Прокси настройки
# ----------------------------------------------------------------------------

# Порт SOCKS5 прокси (по умолчанию: 1080)
SOCKS5_PORT=1080

# Аутентификация SOCKS5 (опционально)
# Раскомментируйте для включения аутентификации
#SOCKS5_USER=myuser
#SOCKS5_PASS=mypassword

# ----------------------------------------------------------------------------
# NFQUEUE настройки
# ----------------------------------------------------------------------------

# Номер очереди NFQUEUE (по умолчанию: 200)
NFQUEUE_NUM=200

# Метка для обхода петли (по умолчанию: 0x40000000)
DESYNC_MARK=0x40000000

# ----------------------------------------------------------------------------
# Zapret2 / nfqws2 настройки
# ----------------------------------------------------------------------------

# Включить nfqws2 (1 = включено, 0 = выключено)
NFQWS2_ENABLE=1

# Отключить IPv6 (1 = отключено, 0 = включено)
DISABLE_IPV6=1

# Порты для обработки
NFQWS2_PORTS_TCP=80,443
NFQWS2_PORTS_UDP=443

# Лимиты пакетов для connbytes
NFQWS2_TCP_PKT_OUT=20
NFQWS2_TCP_PKT_IN=10
NFQWS2_UDP_PKT_OUT=5
NFQWS2_UDP_PKT_IN=3

# ----------------------------------------------------------------------------
# Стратегия обхода DPI
# ----------------------------------------------------------------------------
# Используйте blockcheck2 для подбора оптимальной стратегии:
# ./docker/blockcheck-runner.sh "youtube.com"
# ----------------------------------------------------------------------------

# Параметры nfqws2 (многострочная переменная)
# Базовая стратегия (HTTP + HTTPS)
NFQWS2_OPT="--filter-tcp=80 --filter-l7=http --payload=http_req --lua-desync=fake:blob=fake_default_http:tcp_md5 --lua-desync=multisplit:pos=method+2 --new --filter-tcp=443 --filter-l7=tls --payload=tls_client_hello --lua-desync=fake:blob=fake_default_tls:tcp_md5:tcp_seq=-10000 --lua-desync=multidisorder:pos=1,midsld --new --filter-udp=443 --filter-l7=quic --payload=quic_initial --lua-desync=fake:blob=fake_default_quic:repeats=6"

# Примеры других стратегий:

# Агрессивная стратегия для YouTube
#NFQWS2_OPT="--filter-tcp=443 --filter-l7=tls --hostlist=/opt/zapret2/lists/youtube.txt --payload=tls_client_hello --lua-desync=fake:blob=fake_default_tls:tcp_md5:repeats=11:tls_mod=rnd,dupsid,sni=www.google.com --lua-desync=multidisorder:pos=1,midsld"

# Простая стратегия с fake пакетами
#NFQWS2_OPT="--filter-tcp=443 --filter-l7=tls --payload=tls_client_hello --lua-desync=fake:blob=fake_default_tls:tcp_md5:repeats=6"

# Стратегия с multisplit
#NFQWS2_OPT="--filter-tcp=443 --filter-l7=tls --payload=tls_client_hello --lua-desync=multisplit:pos=sni"

# QUIC поддержка
#NFQWS2_OPT="--filter-udp=443 --filter-l7=quic --payload=quic_initial --lua-desync=fake:blob=fake_default_quic:repeats=11"

# ----------------------------------------------------------------------------
# Режим фильтрации
# ----------------------------------------------------------------------------
# none - обрабатывать весь трафик
# ipset - использовать ipset списки
# hostlist - использовать списки доменов
# autohostlist - автоматическое определение
MODE_FILTER=none

# ----------------------------------------------------------------------------
# Логирование
# ----------------------------------------------------------------------------

# Уровень логирования: info или debug
LOG_LEVEL=info

# Включить подробные логи curl (для отладки)
CURL_VERBOSE=0

# ----------------------------------------------------------------------------
# Пользователь и группа для nfqws2
# ----------------------------------------------------------------------------

WS_UID=1
WS_GID=3003

# ----------------------------------------------------------------------------
# Дополнительные параметры nfqws2
# ----------------------------------------------------------------------------
# Эти параметры добавляются ДО основных параметров
#PKTWS_EXTRA_PRE="--debug"

# Эти параметры добавляются ПОСЛЕ основных параметров
#PKTWS_EXTRA_POST="--out-range=-d10"

# ----------------------------------------------------------------------------
# BlockCheck2 настройки (для подбора стратегии)
# ----------------------------------------------------------------------------

# Пропустить проверку DNS
SKIP_DNSCHECK=1

# Использовать DoH (DNS over HTTPS)
SECURE_DNS=0

# IP версии для тестирования: 4, 6 или 46
IPVS=4

# Включить тесты протоколов
ENABLE_HTTP=0
ENABLE_HTTPS_TLS12=1
ENABLE_HTTPS_TLS13=1
ENABLE_HTTP3=0

# Количество повторов тестов
REPEATS=2

# Параллельное сканирование (0 = выключено, 1 = включено)
PARALLEL=1

# Уровень сканирования: quick, standard, force
SCANLEVEL=standard

# Batch режим (без интерактивных вопросов)
BATCH=1

# Домены для тестирования (разделенные пробелами)
DOMAINS="youtube.com googlevideo.com"

# Тип теста (standard или custom)
TEST=standard

# ----------------------------------------------------------------------------
# Docker настройки
# ----------------------------------------------------------------------------

# Имя контейнера
CONTAINER_NAME=zapret2-proxy

# Имя образа
IMAGE_NAME=zapret2-proxy

# Режим перезапуска
RESTART_POLICY=unless-stopped

# Сетевой режим
NETWORK_MODE=bridge

# ----------------------------------------------------------------------------
# Пути к файлам (внутри контейнера)
# ----------------------------------------------------------------------------

# Путь к конфигурации zapret
ZAPRET_CONFIG=/opt/zapret2/config

# Путь к базовой директории zapret
ZAPRET_BASE=/opt/zapret2

# Путь к временным файлам
ZAPRET_TMP=/opt/zapret2/tmp

# ----------------------------------------------------------------------------
# Монтирование volumes (на хосте)
# ----------------------------------------------------------------------------
# Раскомментируйте нужные пути для монтирования

# Кастомная конфигурация
#CONFIG_PATH=./config

# Списки доменов
#LISTS_PATH=./lists

# Логи
#LOGS_PATH=./logs

# Кастомные lua скрипты
#LUA_PATH=./custom-lua

# ----------------------------------------------------------------------------
# Системные параметры
# ----------------------------------------------------------------------------

# IP forwarding (должно быть 1)
SYSCTL_IP_FORWARD=1

# Route localnet (должно быть 1)
SYSCTL_ROUTE_LOCALNET=1

# ----------------------------------------------------------------------------
# Healthcheck настройки
# ----------------------------------------------------------------------------

# Интервал проверки здоровья (секунды)
HEALTHCHECK_INTERVAL=30

# Таймаут проверки (секунды)
HEALTHCHECK_TIMEOUT=10

# Количество повторов
HEALTHCHECK_RETRIES=3

# Время старта (секунды)
HEALTHCHECK_START_PERIOD=10

# ----------------------------------------------------------------------------
# Дополнительные опции
# ----------------------------------------------------------------------------

# Симуляция тестов (для отладки blockcheck2)
SIMULATE=0

# Процент успеха при симуляции
SIM_SUCCESS_RATE=10

# Показать полный лог blockcheck2
SHOW_FULL_LOG=0

# Пропустить проверку уже запущенных процессов
SKIP_ALREADY_RUNNING=0

# Пропустить тесты pktws
SKIP_PKTWS=0

# Пропустить тесты блокировки IP
SKIP_IPBLOCK=0

# ----------------------------------------------------------------------------
# Примечания
# ----------------------------------------------------------------------------
# 1. После изменения .env файла перезапустите контейнер:
#    docker-compose down && docker-compose up -d
#
# 2. Для подбора оптимальной стратегии используйте:
#    ./docker/blockcheck-runner.sh "ваш-домен.com"
#
# 3. Скопируйте найденную стратегию в NFQWS2_OPT
#
# 4. Для отладки установите LOG_LEVEL=debug
#
# 5. Документация: docker/README.md
# ============================================================================